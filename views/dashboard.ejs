<%
  const items = myItems || [];
  const lostItems = items.filter(item => item.type === 'lost');
  const foundItems = items.filter(item => item.type === 'found');
  const resolvedItems = items.filter(item => item.status === 'resolved');
  const openItems = items.filter(item => item.status !== 'resolved');
  const latestItem = items
    .slice()
    .sort((a, b) => new Date(b.createdAt || b.dateLost) - new Date(a.createdAt || a.dateLost))[0];
%>

<section class="dashboard-hero">
  <div class="page-hero dashboard-hero__panel">
    <div>
      <span class="badge-soft"><i class="bi bi-grid me-2"></i>Dashboard</span>
      <h2 class="mt-3 mb-2">Your reporting hub</h2>
      <p class="text-muted mb-3">
        Track every report, spot trends, and take action faster.
        <% if (latestItem) { %>
          Latest activity: <strong><%= latestItem.name %></strong> on
          <strong><%= new Date(latestItem.dateLost || latestItem.createdAt).toLocaleDateString() %></strong>.
        <% } %>
      </p>
    </div>
    <div class="dashboard-hero__actions">
      <a href="/items/report" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Report New Item
      </a>
      <a href="/items/report" class="btn btn-ghost">
        <i class="bi bi-upload me-1"></i>Share Update
      </a>
    </div>
  </div>

  <div class="stat-grid dashboard-stats">
    <div class="stat-card">
      <span>All Reports</span>
      <h3 class="mb-0"><%= items.length %></h3>
    </div>
    <div class="stat-card">
      <span>Open Cases</span>
      <h3 class="mb-0"><%= openItems.length %></h3>
    </div>
    <div class="stat-card">
      <span>Lost Items</span>
      <h3 class="mb-0"><%= lostItems.length %></h3>
    </div>
    <div class="stat-card">
      <span>Found Items</span>
      <h3 class="mb-0"><%= foundItems.length %></h3>
    </div>
  </div>
</section>

<div class="row g-4">
  <div class="col-lg-3">
    <aside class="sidebar-card dashboard-sidebar">
      <h5 class="mb-3">Quick Actions</h5>
      <div class="list-group dashboard-nav">
        <a href="/dashboard" class="list-group-item list-group-item-action active">
          <i class="bi bi-collection me-2"></i>My Reports
        </a>
        <a href="/items/report" class="list-group-item list-group-item-action">
          <i class="bi bi-plus-circle me-2"></i>Report New Item
        </a>
        <a href="/items/report" class="list-group-item list-group-item-action">
          <i class="bi bi-bell me-2"></i>Notify Admin
        </a>
      </div>
      <div class="dashboard-note mt-4">
        <h6 class="mb-2"><i class="bi bi-lightning-charge me-2"></i>Pro Tip</h6>
        <p class="text-muted mb-0">Add clear photos and exact locations to speed up matches.</p>
      </div>
    </aside>
  </div>

  <div class="col-lg-9">
    <div class="dashboard-header">
      <h3 class="mb-0">My Reported Items</h3>
      <div class="dashboard-header__meta text-muted">
        <i class="bi bi-clock-history me-2"></i>
        Updated <%= new Date().toLocaleDateString() %>
      </div>
    </div>

    <% if (claimRequests && claimRequests.length) { %>
      <div class="dashboard-claims mb-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <h5 class="mb-0">Claim Requests</h5>
          <span class="badge rounded-pill bg-danger"><%= claimRequests.length %></span>
        </div>
        <div class="row g-3">
          <% claimRequests.forEach((req) => { %>
            <div class="col-12">
              <div class="card border-0 shadow-sm">
                <div class="card-body">
                  <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
                    <div>
                      <h6 class="mb-1"><%= req.itemName %> <span class="text-muted">(<%= req.itemType %>)</span></h6>
                      <p class="mb-1 text-muted small">Claimant: <%= req.claim.claimantName %></p>
                      <% if (req.claim.description) { %>
                        <p class="mb-2"><%= req.claim.description %></p>
                      <% } %>
                      <% if (req.claim.proofPath) { %>
                        <a href="<%= req.claim.proofPath %>" class="btn btn-outline-primary btn-sm" target="_blank">View proof</a>
                      <% } %>
                    </div>
                    <div class="d-flex gap-2">
                      <form method="post" action="/items/<%= req.itemId %>/claim/<%= req.claim.id %>/accept">
                        <button class="btn btn-primary btn-sm" type="submit">Accept</button>
                      </form>
                      <form method="post" action="/items/<%= req.itemId %>/claim/<%= req.claim.id %>/deny">
                        <button class="btn btn-outline-secondary btn-sm" type="submit">Deny</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <ul class="nav nav-pills dashboard-tabs" id="dashboardTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tab-all" data-bs-toggle="pill" data-bs-target="#panel-all" type="button" role="tab">
          All <span class="ms-1 badge rounded-pill bg-light text-dark"><%= items.length %></span>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-lost" data-bs-toggle="pill" data-bs-target="#panel-lost" type="button" role="tab">
          Lost <span class="ms-1 badge rounded-pill bg-light text-dark"><%= lostItems.length %></span>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-found" data-bs-toggle="pill" data-bs-target="#panel-found" type="button" role="tab">
          Found <span class="ms-1 badge rounded-pill bg-light text-dark"><%= foundItems.length %></span>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-resolved" data-bs-toggle="pill" data-bs-target="#panel-resolved" type="button" role="tab">
          Resolved <span class="ms-1 badge rounded-pill bg-light text-dark"><%= resolvedItems.length %></span>
        </button>
      </li>
    </ul>

    <div class="tab-content dashboard-tab-content">
      <div class="tab-pane fade show active" id="panel-all" role="tabpanel" aria-labelledby="tab-all">
        <% if (items.length > 0) { %>
          <div class="row g-3">
            <% items.forEach(item => { %>
              <div class="col-md-6 col-xl-4">
                <div class="card h-100 dashboard-card">
                  <% if (item.photoPath) { %>
                    <img src="<%= item.photoPath %>" class="card-img-top" alt="<%= item.name %>">
                  <% } else { %>
                    <div class="dashboard-card__image">
                      <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                  <% } %>
                  <div class="card-body">
                    <div class="d-flex justify-content-between mb-2 flex-wrap gap-2">
                      <span class="badge bg-<%= item.type === 'lost' ? 'danger' : 'success' %>"><%= item.type.toUpperCase() %></span>
                      <span class="badge bg-<%= item.status === 'resolved' ? 'success' : 'secondary' %>"><%= item.status %></span>
                    </div>
                    <h5 class="card-title text-truncate"><%= item.name %></h5>
                    <div class="dashboard-card__meta">
                      <span><i class="bi bi-geo-alt me-1"></i><%= item.location %></span>
                      <span><i class="bi bi-calendar me-1"></i><%= new Date(item.dateLost || item.createdAt).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <div class="card-footer bg-white">
                    <a href="/items/<%= item.id %>" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <i class="bi bi-folder2-open display-4 text-muted"></i>
            <p class="mt-3 text-muted">You haven't reported any items yet.</p>
            <a href="/items/report" class="btn btn-primary mt-2">Report an Item</a>
          </div>
        <% } %>
      </div>

      <div class="tab-pane fade" id="panel-lost" role="tabpanel" aria-labelledby="tab-lost">
        <% if (lostItems.length > 0) { %>
          <div class="row g-3">
            <% lostItems.forEach(item => { %>
              <div class="col-md-6 col-xl-4">
                <div class="card h-100 dashboard-card">
                  <% if (item.photoPath) { %>
                    <img src="<%= item.photoPath %>" class="card-img-top" alt="<%= item.name %>">
                  <% } else { %>
                    <div class="dashboard-card__image">
                      <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                  <% } %>
                  <div class="card-body">
                    <div class="d-flex justify-content-between mb-2 flex-wrap gap-2">
                      <span class="badge bg-<%= item.type === 'lost' ? 'danger' : 'success' %>"><%= item.type.toUpperCase() %></span>
                      <span class="badge bg-<%= item.status === 'resolved' ? 'success' : 'secondary' %>"><%= item.status %></span>
                    </div>
                    <h5 class="card-title text-truncate"><%= item.name %></h5>
                    <div class="dashboard-card__meta">
                      <span><i class="bi bi-geo-alt me-1"></i><%= item.location %></span>
                      <span><i class="bi bi-calendar me-1"></i><%= new Date(item.dateLost || item.createdAt).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <div class="card-footer bg-white">
                    <a href="/items/<%= item.id %>" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <i class="bi bi-emoji-frown display-4 text-muted"></i>
            <p class="mt-3 text-muted">No lost items yet. You're in the clear.</p>
          </div>
        <% } %>
      </div>

      <div class="tab-pane fade" id="panel-found" role="tabpanel" aria-labelledby="tab-found">
        <% if (foundItems.length > 0) { %>
          <div class="row g-3">
            <% foundItems.forEach(item => { %>
              <div class="col-md-6 col-xl-4">
                <div class="card h-100 dashboard-card">
                  <% if (item.photoPath) { %>
                    <img src="<%= item.photoPath %>" class="card-img-top" alt="<%= item.name %>">
                  <% } else { %>
                    <div class="dashboard-card__image">
                      <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                  <% } %>
                  <div class="card-body">
                    <div class="d-flex justify-content-between mb-2 flex-wrap gap-2">
                      <span class="badge bg-<%= item.type === 'lost' ? 'danger' : 'success' %>"><%= item.type.toUpperCase() %></span>
                      <span class="badge bg-<%= item.status === 'resolved' ? 'success' : 'secondary' %>"><%= item.status %></span>
                    </div>
                    <h5 class="card-title text-truncate"><%= item.name %></h5>
                    <div class="dashboard-card__meta">
                      <span><i class="bi bi-geo-alt me-1"></i><%= item.location %></span>
                      <span><i class="bi bi-calendar me-1"></i><%= new Date(item.dateLost || item.createdAt).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <div class="card-footer bg-white">
                    <a href="/items/<%= item.id %>" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <i class="bi bi-emoji-smile display-4 text-muted"></i>
            <p class="mt-3 text-muted">No found items yet. Keep an eye out!</p>
          </div>
        <% } %>
      </div>

      <div class="tab-pane fade" id="panel-resolved" role="tabpanel" aria-labelledby="tab-resolved">
        <% if (resolvedItems.length > 0) { %>
          <div class="row g-3">
            <% resolvedItems.forEach(item => { %>
              <div class="col-md-6 col-xl-4">
                <div class="card h-100 dashboard-card">
                  <% if (item.photoPath) { %>
                    <img src="<%= item.photoPath %>" class="card-img-top" alt="<%= item.name %>">
                  <% } else { %>
                    <div class="dashboard-card__image">
                      <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                  <% } %>
                  <div class="card-body">
                    <div class="d-flex justify-content-between mb-2 flex-wrap gap-2">
                      <span class="badge bg-<%= item.type === 'lost' ? 'danger' : 'success' %>"><%= item.type.toUpperCase() %></span>
                      <span class="badge bg-success"><%= item.status %></span>
                    </div>
                    <h5 class="card-title text-truncate"><%= item.name %></h5>
                    <div class="dashboard-card__meta">
                      <span><i class="bi bi-geo-alt me-1"></i><%= item.location %></span>
                      <span><i class="bi bi-calendar me-1"></i><%= new Date(item.dateLost || item.createdAt).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <div class="card-footer bg-white">
                    <a href="/items/<%= item.id %>" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <i class="bi bi-stars display-4 text-muted"></i>
            <p class="mt-3 text-muted">No resolved items yet. You're close!</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
