<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Lost2Found</title>
    <meta
      name="description"
      content="Reconnect lost items with their owners across campus through a trusted lost & found network."
    />
    <meta name="theme-color" content="#1aa6a0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-..."
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/css/styles.css" />
    <style>
      /* Chat Popup & Overlay */
      .chat-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1050;
        pointer-events: none;
      }
      .chat-container.is-open {
        pointer-events: auto;
      }
      .chat-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .chat-container.is-open .chat-overlay {
        opacity: 1;
      }
      .chat-popup {
        position: absolute;
        top: 0;
        right: 0;
        width: 100%;
        max-width: 420px;
        height: 100%;
        background-color: #fff;
        transform: translateX(100%);
        transition: transform 0.3s ease-in-out;
        display: flex;
        flex-direction: column;
      }
      .chat-container.is-open .chat-popup {
        transform: translateX(0);
      }
      body.chat-open {
        overflow: hidden;
      }

      /* Chat Bubbles */
      .message-wrapper {
        display: flex;
        margin-bottom: 0.5rem;
        width: 100%;
      }
      .message-wrapper.sent {
        justify-content: flex-end;
      }
      .message-wrapper.received {
        justify-content: flex-start;
      }
      .message-bubble {
        max-width: 75%;
        padding: 0.5rem 1rem;
        border-radius: 1.25rem;
        word-wrap: break-word;
        position: relative;
      }
      .message-wrapper.sent .message-bubble {
        background-color: var(--chat-teal, #1aa6a0);
        color: white;
        border-bottom-right-radius: 0.25rem;
      }
      .message-wrapper.received .message-bubble {
        background-color: #ffffff;
        color: #1e293b;
        border: 1px solid #e2e8f0;
        border-bottom-left-radius: 0.25rem;
      }
    </style>
  </head>
  <body
    class="app-shell"
    data-user-id="<%= currentUser ? currentUser.id : '' %>"
    data-user-name="<%= currentUser ? currentUser.name : '' %>"
  >
    <%- include('partials/header') %>

    <main class="container py-4">
      <%- include('partials/messages') %> <%- body %>
    </main>

    <%- include('partials/footer') %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-..."
      crossorigin="anonymous"
    ></script>
    <script src="/js/app.js?v=<%= Date.now() %>"></script>
  </body>
</html>
