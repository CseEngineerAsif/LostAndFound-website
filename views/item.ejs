<div class="row g-4">
  <div class="col-lg-8">
    <div class="card">
      <% if (item.photoPath) { %>
      <img src="<%= item.photoPath %>" class="card-img-top" alt="Item photo" />
      <% } %>
      <div class="card-body">
        <% const itemStatus = item.status || 'reported'; %>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
          <h1 class="card-title mb-0"><%= item.name %></h1>
          <span class="status-pill status-<%= itemStatus %>"><%= itemStatus === 'resolved' ? 'Returned' : itemStatus %></span>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <span class="tag"><i class="bi bi-tag"></i><%= item.category %></span>
          <span class="tag"><i class="bi bi-flag"></i><%= item.type %></span>
          <span class="tag"><i class="bi bi-geo-alt"></i><%= item.location %></span>
        </div>
        <div class="mt-3 text-muted">
          <p class="mb-1"><strong>Reported on:</strong> <%= new Date(item.createdAt).toLocaleString() %></p>
          <% if (item.dateLost) { %>
          <p class="mb-1"><strong>Date noted:</strong> <%= item.dateLost %></p>
          <% } %>
          <% if (item.contactMethod) { %>
          <p class="mb-1"><strong>Contact:</strong> <%= item.contactMethod %></p>
          <% } %>
          <% if (item.reportedByName) { %>
          <p class="mb-1"><strong>Posted by:</strong> <%= item.anonymous ? 'Anonymous' : item.reportedByName %></p>
          <% } else { %>
          <p class="mb-1"><strong>Posted by:</strong> Anonymous</p>
          <% } %>
          <% if (item.updatedAt) { %>
          <p class="mb-1"><strong>Last updated:</strong> <%= new Date(item.updatedAt).toLocaleString() %></p>
          <% } %>
        </div>
        <hr />
        <p><%= item.description || 'No description provided.' %></p>

        <div class="mt-4 d-flex gap-2 flex-wrap">
          <a href="/items/search" class="btn btn-outline-primary">
            Back to feed
          </a>
          <button class="btn btn-outline-primary" data-copy-link>
            <i class="bi bi-link-45deg me-1"></i>Copy share link
          </button>
          <button class="btn btn-primary">
            <i class="bi bi-chat-dots me-1"></i>Contact owner
          </button>
          <button class="btn btn-ghost">
            <i class="bi bi-check-circle me-1"></i>Report as claimed
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card sidebar-card p-4">
      <h5 class="mb-3">Claim verification</h5>
      <div class="text-center">
        <div class="p-3 rounded" style="background: rgba(26, 166, 160, 0.1);">
          <svg width="160" height="160" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="120" height="120" rx="12" fill="#f8fafc" />
            <rect x="12" y="12" width="32" height="32" rx="6" fill="#1e3a8a" />
            <rect x="76" y="12" width="32" height="32" rx="6" fill="#1e3a8a" />
            <rect x="12" y="76" width="32" height="32" rx="6" fill="#1e3a8a" />
            <rect x="52" y="52" width="16" height="16" rx="4" fill="#3b82f6" />
            <rect x="76" y="76" width="16" height="16" rx="4" fill="#10b981" />
            <rect x="52" y="20" width="12" height="12" rx="3" fill="#10b981" />
            <rect x="28" y="52" width="12" height="12" rx="3" fill="#3b82f6" />
          </svg>
        </div>
        <p class="text-muted mt-3 mb-0">Scan to verify the claim at pickup.</p>
      </div>

      <hr />
      <h6 class="mb-2">AI match suggestions</h6>
      <div class="d-grid gap-2">
        <% if (matches && matches.length) { %>
        <% matches.forEach((match) => { %>
        <div class="p-3 rounded" style="background: rgba(26, 166, 160, 0.1);">
          <strong><%= match.name %></strong>
          <div class="small text-muted"><%= match.location %></div>
        </div>
        <% }) %>
        <% } else { %>
        <div class="p-3 rounded" style="background: rgba(26, 166, 160, 0.1);">
          <strong>No suggestions yet</strong>
          <div class="small text-muted">Check back as more items are reported.</div>
        </div>
        <% } %>
      </div>

      <% if (isOwner && itemStatus !== 'resolved') { %>
      <hr />
      <h6 class="mb-2">Update status</h6>
      <form method="post" action="/items/<%= item.id %>/status" class="d-grid gap-2">
        <input type="hidden" name="status" value="resolved" />
        <button class="btn btn-primary" type="submit">Mark as returned</button>
      </form>
      <% } else if (isOwner && itemStatus === 'resolved') { %>
      <div class="mt-4 p-3 rounded" style="background: rgba(16, 185, 129, 0.12);">
        <strong class="d-block mb-1">Marked returned</strong>
        <span class="text-muted">Thanks for keeping the community updated.</span>
      </div>
      <% } %>
    </div>
  </div>
</div>
