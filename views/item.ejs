<div class="row g-4">
  <% const itemStatus = item.status || 'reported'; %>
  <% const adminReturnConfirmedAt = item.returnAdminConfirmedAt ? new Date(item.returnAdminConfirmedAt) : null; %>
  <div class="col-lg-8">
    <div class="card">
      <% if (editMode && (isOwner || (currentUser && currentUser.role === 'admin'))) { %>
      <!-- Edit Form -->
      <div class="card-body">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <h2 class="card-title mb-2">Edit Item Details</h2>
            <p class="text-muted mb-4">Update the information for this report.</p>
          </div>
          <a href="/items/<%= item.id %>" class="btn btn-outline-secondary">Cancel</a>
        </div>
        <form method="post" action="/items/<%= item.id %>/update" enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Report type</label>
              <select name="type" class="form-select" required>
                <option value="lost" <%= item.type === 'lost' ? 'selected' : '' %>>Lost</option>
                <option value="found" <%= item.type === 'found' ? 'selected' : '' %>>Found</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Category</label>
              <select name="category" class="form-select" required>
                <option value="Phone" <%= item.category === 'Phone' ? 'selected' : '' %>>Phone</option>
                <option value="Wallet" <%= item.category === 'Wallet' ? 'selected' : '' %>>Wallet</option>
                <option value="Bag" <%= item.category === 'Bag' ? 'selected' : '' %>>Bag</option>
                <option value="ID Card" <%= item.category === 'ID Card' ? 'selected' : '' %>>ID Card</option>
                <option value="Educational Tool" <%= item.category === 'Educational Tool' ? 'selected' : '' %>>Educational Tool</option>
                <option value="Books" <%= item.category === 'Books' ? 'selected' : '' %>>Books</option>
                <option value="Electronics" <%= item.category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                <option value="Others" <%= item.category === 'Others' ? 'selected' : '' %>>Others</option>
              </select>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Item name</label>
            <input type="text" name="name" class="form-control" value="<%= item.name %>" required />
          </div>

          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control" rows="4"><%= item.description || '' %></textarea>
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Location</label>
              <input type="text" name="location" class="form-control" value="<%= item.location %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Date lost/found</label>
              <input type="date" name="dateLost" class="form-control" value="<%= item.dateLost %>" required />
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-6">
              <label class="form-label">Contact method</label>
              <input type="text" name="contactMethod" class="form-control" value="<%= item.contactMethod %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Post as</label>
              <select name="anonymous" class="form-select">
                <option value="false" <%= !item.anonymous ? 'selected' : '' %>>Show my name</option>
                <option value="true" <%= item.anonymous ? 'selected' : '' %>>Anonymous</option>
              </select>
            </div>
          </div>

          <div class="mb-3 mt-3">
            <label class="form-label">Update photo (optional)</label>
            <input type="file" name="photo" accept="image/*" class="form-control" />
            <% if (item.photoPath) { %>
            <div class="mt-2">
              <small class="text-muted">Current photo:</small><br>
              <img src="<%= item.photoPath %>" alt="Current photo" style="max-width: 200px; max-height: 200px;" />
            </div>
            <% } %>
          </div>

          <button class="btn btn-primary w-100" type="submit">
            <i class="bi bi-save me-2"></i>Update Item
          </button>
        </form>
      </div>
      <% } else { %>
      <!-- View Mode -->
      <% if (item.photoPath) { %>
      <img src="<%= item.photoPath %>" class="card-img-top" alt="Item photo" />
      <% } %>
      <div class="card-body">
        <% const itemStatus = item.status || 'reported'; %>
        <% const activeReturnClaim = (item.claims || []).find((claim) => claim.returnStatus === 'requested'); %>
        <% if ((isOwner || (currentUser && currentUser.role === 'admin')) && itemStatus === 'return_pending' && activeReturnClaim) { %>
          <div class="alert alert-warning d-flex align-items-start gap-3">
            <i class="bi bi-exclamation-triangle fs-4"></i>
            <div>
              <strong>Return requested.</strong>
              <% if (activeReturnClaim.returnDueAt) { %>
                Please collect the item back by <%= new Date(activeReturnClaim.returnDueAt).toLocaleDateString() %>.
              <% } else { %>
                Please collect the item back within 5 days.
              <% } %>
            </div>
          </div>
        <% } %>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
          <h1 class="card-title mb-0"><%= item.name %></h1>
          <div class="d-flex gap-2">
            <% if (isOwner || (currentUser && currentUser.role === 'admin')) { %>
            <a href="/items/<%= item.id %>?edit=true" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <% } %>
            <span class="status-pill status-<%= itemStatus %>"><%= itemStatus === 'resolved' ? 'Returned' : itemStatus %></span>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <span class="tag"><i class="bi bi-tag"></i><%= item.category %></span>
          <span class="tag"><i class="bi bi-flag"></i><%= item.type %></span>
          <span class="tag"><i class="bi bi-geo-alt"></i><%= item.location %></span>
        </div>
        <div class="mt-3 text-muted">
          <p class="mb-1"><strong>Reported on:</strong> <%= new Date(item.createdAt).toLocaleString() %></p>
          <% if (item.dateLost) { %>
          <p class="mb-1"><strong>Date noted:</strong> <%= item.dateLost %></p>
          <% } %>
          <% if (item.contactMethod) { %>
          <p class="mb-1"><strong>Contact:</strong> <%= item.contactMethod %></p>
          <% } %>
          <% if (item.reportedByName) { %>
          <p class="mb-1"><strong>Posted by:</strong> <%= item.anonymous ? 'Anonymous' : item.reportedByName %></p>
          <% } else { %>
          <p class="mb-1"><strong>Posted by:</strong> Anonymous</p>
          <% } %>
          <% if (item.updatedAt) { %>
          <p class="mb-1"><strong>Last updated:</strong> <%= new Date(item.updatedAt).toLocaleString() %></p>
          <% } %>
        </div>
        <hr />
        <p><%= item.description || 'No description provided.' %></p>

        <div class="mt-4 d-flex gap-2 flex-wrap">
          <a href="/items/search" class="btn btn-outline-primary">
            Back to feed
          </a>
          <button class="btn btn-outline-primary" data-copy-link>
            <i class="bi bi-link-45deg me-1"></i>Copy share link
          </button>
          <% if (currentUser && String(currentUser.id) !== String(item.userId)) { %>
            <button type="button" id="open-chat-btn" class="btn btn-primary" data-recipient-id="<%= item.userId %>" data-recipient-name="<%= item.reportedByName || 'User' %>">
              <i class="bi bi-chat-dots me-1"></i>Chat
            </button>
          <% } else if (!currentUser) { %>
            <a href="/auth/login" class="btn btn-primary"><i class="bi bi-chat-dots me-1"></i>Login to Chat</a>
          <% } %>
          <% if (currentUser && String(currentUser.id) !== String(item.userId)) { %>
            <button class="btn btn-ghost" data-bs-toggle="modal" data-bs-target="#claimModal">
              <i class="bi bi-check-circle me-1"></i>Report as claimed
            </button>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card sidebar-card p-4">
      <h5 class="mb-3">Claim verification</h5>
      <div class="text-center">
        <div class="p-3 rounded" style="background: rgba(26, 166, 160, 0.1);">
          <svg width="160" height="160" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="120" height="120" rx="12" fill="#f8fafc" />
            <rect x="12" y="12" width="32" height="32" rx="6" fill="#1e3a8a" />
            <rect x="76" y="12" width="32" height="32" rx="6" fill="#1e3a8a" />
            <rect x="12" y="76" width="32" height="32" rx="6" fill="#1e3a8a" />
            <rect x="52" y="52" width="16" height="16" rx="4" fill="#3b82f6" />
            <rect x="76" y="76" width="16" height="16" rx="4" fill="#10b981" />
            <rect x="52" y="20" width="12" height="12" rx="3" fill="#10b981" />
            <rect x="28" y="52" width="12" height="12" rx="3" fill="#3b82f6" />
          </svg>
        </div>
        <p class="text-muted mt-3 mb-0">Scan to verify the claim at pickup.</p>
      </div>

      <hr />
      <h6 class="mb-2">AI match suggestions</h6>
      <div class="d-grid gap-2">
        <% if (matches && matches.length) { %>
        <% matches.forEach((match) => { %>
        <div class="p-3 rounded" style="background: rgba(26, 166, 160, 0.1);">
          <strong><%= match.name %></strong>
          <div class="small text-muted"><%= match.location %></div>
        </div>
        <% }) %>
        <% } else { %>
        <div class="p-3 rounded" style="background: rgba(26, 166, 160, 0.1);">
          <strong>No suggestions yet</strong>
          <div class="small text-muted">Check back as more items are reported.</div>
        </div>
        <% } %>
      </div>

      <% if (currentUser && currentUser.role === 'admin' && itemStatus !== 'resolved') { %>
      <hr />
      <h6 class="mb-2">Admin return</h6>
      <% if (!adminReturnConfirmedAt) { %>
        <form method="post" action="/items/<%= item.id %>/return-admin" class="d-grid gap-2">
          <button class="btn btn-primary" type="submit">Confirm return to owner</button>
        </form>
      <% } else { %>
        <div class="p-3 rounded" style="background: rgba(26, 166, 160, 0.12);">
          <strong class="d-block mb-1">Admin return recorded</strong>
          <span class="text-muted">Confirmed on <%= adminReturnConfirmedAt.toLocaleString() %>.</span>
        </div>
      <% } %>
      <% } %>

      <% if (isOwner && itemStatus !== 'resolved') { %>
      <hr />
      <h6 class="mb-2">Update status</h6>
      <% if (adminReturnConfirmedAt) { %>
        <form method="post" action="/items/<%= item.id %>/return-success" class="d-grid gap-2">
          <button class="btn btn-primary" type="submit">Mark as successfully returned</button>
        </form>
      <% } else { %>
        <div class="p-3 rounded" style="background: rgba(59, 130, 246, 0.1);">
          <strong class="d-block mb-1">Awaiting admin confirmation</strong>
          <span class="text-muted">An admin must confirm the return before you can mark it completed.</span>
        </div>
      <% } %>
      <% } else if (isOwner && itemStatus === 'resolved') { %>
      <div class="mt-4 p-3 rounded" style="background: rgba(16, 185, 129, 0.12);">
        <strong class="d-block mb-1">Marked returned</strong>
        <span class="text-muted">Thanks for keeping the community updated.</span>
      </div>
      <% } %>
    </div>
  </div>
</div>

<% if (currentUser && String(currentUser.id) !== String(item.userId)) { %>
<!-- Claim Modal -->
<div class="modal fade" id="claimModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Submit a claim</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" action="/items/<%= item.id %>/claim" enctype="multipart/form-data">
        <div class="modal-body">
          <p class="text-muted small mb-3">Provide a short description or a photo proving ownership (e.g., unique mark, sticker, or detail).</p>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control" rows="3" placeholder="Describe a unique detail..."></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">When did you lose it? (optional)</label>
            <input type="date" name="claimedDate" class="form-control" />
          </div>
          <% if (item.verificationQuestions && item.verificationQuestions.length) { %>
            <div class="mb-3">
              <h6 class="mb-2">Verification questions</h6>
              <p class="text-muted small mb-2">Answer all questions so the reporter can verify ownership.</p>
              <div class="d-grid gap-2">
                <% item.verificationQuestions.forEach((entry, index) => { %>
                  <div>
                    <label class="form-label"><%= entry.question %></label>
                    <input type="text" name="answers[]" class="form-control" required />
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
          <div class="mb-2">
            <label class="form-label">Proof photo (optional)</label>
            <input type="file" name="proof" class="form-control" accept="image/*">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Send claim request</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<% if (currentUser && String(currentUser.id) !== String(item.userId)) { %>
<!-- Chat Popup -->
<div id="chat-container" class="chat-container">
  <div id="chat-overlay" class="chat-overlay"></div>
  <div id="chat-popup" class="chat-popup">
    <div class="chat-popup-card chat-theme">
      <div class="chat-popup-header">
        <div class="chat-popup-title">
          <div class="chat-popup-avatar">
            <%= item.reportedByName ? item.reportedByName.charAt(0).toUpperCase() : 'U' %>
          </div>
          <div>
            <h5 class="mb-0 text-truncate" style="max-width: 200px;"><%= item.reportedByName || 'User' %></h5>
            <small class="text-muted">Re: <%= item.name %></small>
            <div id="chat-popup-typing" class="chat-typing"></div>
          </div>
        </div>
        <button id="close-chat-btn" type="button" class="chat-popup-close" aria-label="Close chat">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      
      <div id="chat-box" class="chat-popup-body">
          <!-- Chat history will be loaded here via JavaScript -->
      </div>

      <div class="chat-popup-footer">
        <form id="popup-chat-form" action="/items/<%= item.id %>/chat" method="POST" class="chat-popup-form" data-username="<%= currentUser ? currentUser.name : 'Anonymous' %>">
          <input type="text" name="message" class="form-control chat-popup-input" placeholder="Type a message..." required autocomplete="off">
          <button type="submit" class="chat-popup-send" aria-label="Send message">
            <i class="bi bi-send-fill"></i>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<% } %>
