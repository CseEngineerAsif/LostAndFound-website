<div class="chat-shell chat-theme">
  <aside class="chat-sidebar">
    <div class="chat-sidebar__header">
      <div>
        <span class="eyebrow text-dark">Messages</span>
        <h4 class="mb-0">Conversations</h4>
      </div>
      <button class="btn btn-ghost btn-sm" type="button" aria-label="New chat">
        <i class="bi bi-plus-lg"></i>
      </button>
    </div>

    <div class="chat-search input-group">
      <span class="input-group-text"><i class="bi bi-search"></i></span>
      <input type="text" class="form-control" placeholder="Search people or items" disabled>
    </div>

    <div class="chat-list list-group list-group-flush">
      <% if (conversations && conversations.length > 0) { %>
        <% conversations.forEach(convo => { %>
          <a href="/chat/<%= convo.userId %>" data-user-id="<%= convo.userId %>" class="list-group-item chat-list__item list-group-item-action <%= (activeChat && String(activeChat.user.userId) === String(convo.userId)) ? 'active' : '' %>">
            <div class="chat-avatar"><%= convo.name.charAt(0).toUpperCase() %></div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-1 text-truncate"><%= convo.name %></h6>
                <div class="chat-meta">
                  <% if (convo.lastMessage) { %>
                    <small class="text-muted"><%= new Date(convo.lastMessage.createdAt).toLocaleDateString() %></small>
                  <% } %>
                  <% if (convo.unreadCount && convo.unreadCount > 0) { %>
                    <span class="chat-unread"><%= convo.unreadCount %></span>
                  <% } %>
                </div>
              </div>
              <% if (convo.lastMessage) { %>
                <p class="mb-0 text-muted text-truncate"><%= convo.lastMessage.content %></p>
              <% } else { %>
                <p class="mb-0 text-muted fst-italic">No messages yet.</p>
              <% } %>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <div class="text-center text-muted p-4">
          <i class="bi bi-chat-quote fs-1"></i>
          <p class="mt-2">No conversations yet.</p>
          <p class="small">Start a chat from an item page.</p>
        </div>
      <% } %>
    </div>
  </aside>

  <section class="chat-main">
    <% if (activeChat) { %>
      <header class="chat-header">
        <div class="d-flex align-items-center gap-3">
          <div class="chat-avatar chat-avatar--lg">
            <%= activeChat.user.name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <h5 id="chat-with" class="mb-1 text-truncate">Chat with <%= activeChat.user.name %></h5>
            <div class="chat-status">
              <span class="status-dot"></span>
              Active now
            </div>
            <div id="chat-typing" class="chat-typing"></div>
          </div>
        </div>
        <div class="chat-header__actions">
          <button class="btn btn-ghost btn-sm" type="button"><i class="bi bi-telephone"></i></button>
          <button class="btn btn-ghost btn-sm" type="button"><i class="bi bi-three-dots-vertical"></i></button>
        </div>
      </header>

      <div id="chat-box" class="chat-body">
        <% if (activeChat.messages && activeChat.messages.length > 0) { %>
          <% activeChat.messages.forEach(msg => { %>
            <% const isMe = String(msg.senderId) === String(currentUser.id); %>
            <div class="message-wrapper <%= isMe ? 'sent' : 'received' %>">
              <div class="message-bubble">
                <span class="message-text"><%= msg.content %></span>
                <% if (msg.createdAt) { %>
                  <span class="message-time"><%= new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
                <% } %>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="chat-empty">
            <i class="bi bi-chat-heart"></i>
            <p>No messages yet. Start the conversation!</p>
          </div>
        <% } %>
      </div>

      <div class="chat-input">
        <form id="chat-form" class="d-flex gap-2 align-items-center">
          <button class="btn btn-ghost btn-sm" type="button" aria-label="Add attachment">
            <i class="bi bi-paperclip"></i>
          </button>
          <input type="text" id="message" name="message" class="form-control" placeholder="Type a message..." required autocomplete="off">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-send-fill"></i>
          </button>
        </form>
      </div>
    <% } else { %>
      <div class="chat-placeholder">
        <i class="bi bi-chat-left-text"></i>
        <h5 class="mt-3">Select a conversation</h5>
        <p>Choose a person from the list to continue chatting.</p>
      </div>
    <% } %>
  </section>
</div>
