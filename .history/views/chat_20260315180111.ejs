
<div class="row g-0 chat-container">
<div class="row g-0" style="height: 75vh;">
  <!-- Conversations Sidebar -->
  <div class="col-lg-4 col-md-5 border-end chat-sidebar">
    <div class="p-3 border-bottom">
      <h4 class="mb-0">Chats</h4>
    </div>
    <div class="conversation-list">
      <% if (conversations && conversations.length > 0) { %>
        <% conversations.forEach(conv => { %>
          <a href="/chat/<%= conv.userId %>" class="conversation-item list-group-item list-group-item-action border-0 <%= (activeChat && String(activeChat.user.userId) === String(conv.userId)) ? 'active' : '' %>">
            <div class="d-flex align-items-center">
              <div class="flex-shrink-0 me-3">
                <div class="avatar"><%= conv.name.charAt(0).toUpperCase() %></div>
  <div class="col-lg-4 col-md-5 border-end bg-light">
    <div class="p-3">
      <h4 class="mb-3">Conversations</h4>
      <div class="list-group list-group-flush">
        <% if (conversations && conversations.length > 0) { %>
          <% conversations.forEach(convo => { %>
            <a href="/chat/<%= convo.participant.id %>" class="list-group-item list-group-item-action <%= (activeConversation && activeConversation.id === convo.participant.id) ? 'active' : '' %>">
              <div class="d-flex w-100 justify-content-between">
                <h6 class="mb-1"><%= convo.participant.name %></h6>
                <% if (convo.lastMessage) { %>
                  <small class="text-muted"><%= new Date(convo.lastMessage.createdAt).toLocaleDateString() %></small>
                <% } %>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex w-100 justify-content-between">
                  <h6 class="mb-1"><%= conv.name %></h6>
                  <small class="text-muted"><%= new Date(conv.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></small>
                </div>
                <p class="mb-0 text-muted text-truncate" style="max-width: 200px;"><%= conv.lastMessage %></p>
              </div>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <div class="p-3 text-center text-muted">
          <p class="mb-0">No conversations yet.</p>
          <small>Start a chat from an item page.</small>
        </div>
      <% } %>
              <% if (convo.lastMessage) { %>
                <p class="mb-1 text-muted text-truncate"><%= convo.lastMessage.content %></p>
              <% } else { %>
                <p class="mb-1 text-muted fst-italic">No messages yet.</p>
              <% } %>
            </a>
          <% }) %>
        <% } else { %>
          <div class="text-center text-muted p-4">
            <i class="bi bi-chat-quote fs-1"></i>
            <p class="mt-2">No conversations yet.</p>
            <p class="small">Start a chat from an item page.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Active Chat Window -->
  <div class="col-lg-8 col-md-7 chat-main">
    <% if (activeChat) { %>
      <div class="chat-header p-3 border-bottom d-flex align-items-center">
        <div class="avatar me-3"><%= (activeChat.user.name || 'User').charAt(0).toUpperCase() %></div>
        <h5 id="chat-with" class="mb-0"><%= activeChat.user.name || 'User' %></h5>
      </div>
      <div id="chat-box" class="chat-box p-3">
        <% activeChat.messages.forEach(msg => { %>
          <% const isMe = String(msg.senderId) === String(currentUser.id) %>
          <div class="message-wrapper <%= isMe ? 'sent' : 'received' %>">
            <div class="message-bubble"><%- msg.content %></div>
  <!-- Main Chat Area -->
  <div class="col-lg-8 col-md-7 d-flex flex-column">
    <% if (activeConversation) { %>
      <!-- Chat Header -->
      <div class="card-header bg-white d-flex align-items-center justify-content-between py-3 border-bottom">
        <div class="d-flex align-items-center gap-3">
          <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-weight: bold;">
            <%= activeConversation.name.charAt(0).toUpperCase() %>
          </div>
        <% }) %>
          <div>
            <h5 id="chat-with" class="mb-0 text-truncate" style="max-width: 200px;">Chat with <%= activeConversation.name %></h5>
            <!-- You can add an online status indicator here later -->
          </div>
        </div>
      </div>
      <form id="chat-form" class="chat-form p-3 border-top">
        <input type="text" id="message" class="form-control" placeholder="Type a message..." autocomplete="off" required>
        <button type="submit" class="btn btn-primary btn-icon"><i class="bi bi-send-fill"></i></button>
      </form>

      <!-- Chat Box -->
      <div id="chat-box" class="card-body bg-light flex-grow-1" style="overflow-y: auto; padding: 1rem;">
        <% if (messages && messages.length > 0) { %>
          <% messages.forEach(msg => { %>
            <% const isMe = String(msg.senderId) === String(currentUser.id); %>
            <div class="message-wrapper <%= isMe ? 'sent' : 'received' %>">
              <div class="message-bubble">
                <%= msg.content %>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="text-center text-muted small my-3">No messages yet. Start the conversation!</div>
        <% } %>
      </div>

      <!-- Chat Input -->
      <div class="card-footer bg-white py-3">
        <form id="chat-form" class="d-flex gap-2">
          <input type="text" id="message" name="message" class="form-control" placeholder="Type a message..." required autocomplete="off">
          <button type="submit" class="btn btn-primary"><i class="bi bi-send-fill"></i></button>
        </form>
      </div>

    <% } else { %>
      <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center text-muted">
        <i class="bi bi-chat-left-dots-fill" style="font-size: 4rem;"></i>
        <h4 class="mt-3">Select a conversation</h4>
        <p>Choose a chat from the left to see the messages.</p>
      <!-- Placeholder for when no chat is selected -->
      <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted bg-light">
        <i class="bi bi-chat-left-text" style="font-size: 4rem;"></i>
        <h5 class="mt-3">Select a conversation</h5>
        <p>Choose a person from the list to continue chatting.</p>
      </div>
    <% } %>
  </div>
</div>