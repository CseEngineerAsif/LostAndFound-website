
<div class="row g-0 chat-container">
  <!-- Conversations Sidebar -->
  <div class="col-lg-4 col-md-5 border-end chat-sidebar">
    <div class="p-3 border-bottom">
      <h4 class="mb-0">Chats</h4>
    </div>
    <div class="conversation-list">
      <% if (conversations && conversations.length > 0) { %>
        <% conversations.forEach(conv => { %>
          <a href="/chat/<%= conv.userId %>" class="conversation-item list-group-item list-group-item-action border-0 <%= (activeChat && String(activeChat.user.userId) === String(conv.userId)) ? 'active' : '' %>">
            <div class="d-flex align-items-center">
              <div class="flex-shrink-0 me-3">
                <div class="avatar"><%= conv.name.charAt(0).toUpperCase() %></div>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex w-100 justify-content-between">
                  <h6 class="mb-1"><%= conv.name %></h6>
                  <small class="text-muted"><%= new Date(conv.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></small>
                </div>
                <p class="mb-0 text-muted text-truncate" style="max-width: 200px;"><%= conv.lastMessage %></p>
              </div>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <div class="p-3 text-center text-muted">
          <p class="mb-0">No conversations yet.</p>
          <small>Start a chat from an item page.</small>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Active Chat Window -->
  <div class="col-lg-8 col-md-7 chat-main">
    <% if (activeChat) { %>
      <div class="chat-header p-3 border-bottom d-flex align-items-center">
        <div class="avatar me-3"><%= (activeChat.user.name || 'User').charAt(0).toUpperCase() %></div>
        <h5 id="chat-with" class="mb-0"><%= activeChat.user.name || 'User' %></h5>
      </div>
      <div id="chat-box" class="chat-box p-3">
        <% activeChat.messages.forEach(msg => { %>
          <% const isMe = String(msg.senderId) === String(currentUser.id) %>
          <div class="message-wrapper <%= isMe ? 'sent' : 'received' %>">
            <div class="message-bubble"><%- msg.content %></div>
          </div>
        <% }) %>
      </div>
      <form id="chat-form" class="chat-form p-3 border-top">
        <input type="text" id="message" class="form-control" placeholder="Type a message..." autocomplete="off" required>
        <button type="submit" class="btn btn-primary btn-icon"><i class="bi bi-send-fill"></i></button>
      </form>
    <% } else { %>
      <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center text-muted">
        <i class="bi bi-chat-left-dots-fill" style="font-size: 4rem;"></i>
        <h4 class="mt-3">Select a conversation</h4>
        <p>Choose a chat from the left to see the messages.</p>
      </div>
    <% } %>
  </div>
</div>