<% if (messages.error) { %>
<div class="alert alert-danger" role="alert">
  <%= messages.error.join('<br>') %>
</div>
<% } %>
<% if (messages.success) { %>
<div class="alert alert-success" role="alert">
  <%= messages.success.join('<br>') %>
</div>
<% } %>
<% if (messages.info) { %>
<div class="alert alert-info" role="alert">
  <%= messages.info.join('<br>') %>
</div>
<% } %>
