<div class="row">
  <div class="col-md-8">
    <div class="card">
      <% if (item.photoPath) { %>
      <img src="<%= item.photoPath %>" class="card-img-top" alt="Item photo" style="object-fit: cover; max-height: 360px;" />
      <% } %>
      <div class="card-body">
        <h1 class="card-title"><%= item.name %></h1>
        <p class="text-muted">
          <strong>Category:</strong> <%= item.category %> &middot;
          <strong>Type:</strong> <%= item.type %> &middot;
          <strong>Location:</strong> <%= item.location %>
        </p>
        <p><strong>Reported on:</strong> <%= new Date(item.createdAt).toLocaleString() %></p>
        <p><strong>Status:</strong> <%= item.status %></p>
        <hr />
        <p><%= item.description || 'No description provided.' %></p>

        <div class="mt-3">
          <a href="/items/search" class="btn btn-outline-secondary">Back to search</a>
        </div>
      </div>
    </div>
  </div>
</div>
