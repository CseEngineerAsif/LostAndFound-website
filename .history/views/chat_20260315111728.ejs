<% if (currentUser && String(currentUser.id) !== String(item.userId)) { %>
  <a href="/items/<%= item.id %>/chat" class="btn btn-primary">
    <i class="bi bi-chat-dots-fill"></i> Chat with User
  </a>
<% } %>
<%- include('partials/header') %>

<div class="container py-4">
  <div class="row mb-4">
    <div class="col">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
          <li class="breadcrumb-item">
            <a href="/items/<%= item.type === 'lost' ? 'lost' : 'found' %>"
              ><%= item.type === 'lost' ? 'Lost Items' : 'Found Items' %></a
            >
          </li>
          <li class="breadcrumb-item">
            <a href="/items/<%= item.id %>"><%= item.name %></a>
          </li>
          <li class="breadcrumb-item active" aria-current="page">Chat</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow-sm h-100">
        <div
          class="card-header bg-white d-flex align-items-center justify-content-between py-3"
        >
          <div class="d-flex align-items-center gap-3">
            <div
              class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
              style="width: 40px; height: 40px; font-weight: bold"
            >
              <%= item.reportedByName ?
              item.reportedByName.charAt(0).toUpperCase() : 'U' %>
            </div>
            <div>
              <h5 class="mb-0 text-truncate" style="max-width: 200px">
                <%= item.reportedByName || 'User' %>
              </h5>
              <small class="text-muted">Re: <%= item.name %></small>
            </div>
          </div>
          <a
            href="/items/<%= item.id %>"
            class="btn btn-outline-secondary btn-sm"
            ><i class="bi bi-x-lg"></i
          ></a>
        </div>

        <div class="card-body bg-light" style="height: 400px; overflow-y: auto">
          <div class="text-center text-muted small my-3">
            Started chat regarding <strong><%= item.name %></strong>
            <br />
            <%= new Date().toLocaleDateString() %>
          </div>
          <!-- Chat history would appear here -->
        </div>

        <div class="card-footer bg-white py-3">
          <form
            action="/items/<%= item.id %>/chat"
            method="POST"
            class="d-flex gap-2"
          >
            <input
              type="text"
              name="message"
              class="form-control"
              placeholder="Type a message..."
              required
              autocomplete="off"
            />
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-send-fill"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
