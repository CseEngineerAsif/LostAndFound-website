<div class="row">
  <div class="col">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
      <div>
        <h1 class="display-5 mb-1">Welcome, <%= currentUser.name %></h1>
        <p class="text-muted">Manage your reports, find matches, and stay connected with campus.</p>
      </div>
      <div>
        <a href="/items/report" class="btn btn-primary btn-lg">
          <i class="bi bi-journal-plus me-2"></i>Report an item
        </a>
      </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div>
                <h5 class="card-title mb-1">Report an item</h5>
                <p class="text-muted mb-0">Share what you lost or found so others can recover it quickly.</p>
              </div>
              <span class="fs-3 text-primary"><i class="bi bi-journal-plus"></i></span>
            </div>
            <div class="mt-auto">
              <a href="/items/report" class="btn btn-outline-primary w-100">Go to report</a>
            </div>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div>
                <h5 class="card-title mb-1">Search items</h5>
                <p class="text-muted mb-0">Find matches by name, category, or location across the campus.</p>
              </div>
              <span class="fs-3 text-primary"><i class="bi bi-search"></i></span>
            </div>
            <div class="mt-auto">
              <a href="/items/search" class="btn btn-outline-primary w-100">Start searching</a>
            </div>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div>
                <h5 class="card-title mb-1">My reports</h5>
                <p class="text-muted mb-0">Coming soon: track your reported items and matches in one place.</p>
              </div>
              <span class="fs-3 text-muted"><i class="bi bi-clock-history"></i></span>
            </div>
            <div class="mt-auto">
              <button class="btn btn-secondary w-100" disabled>Coming soon</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
